# Example environment variables for JornalGremio
# Copy this file to .env and set real values (do NOT commit .env)

# Email settings for the contact form
CONTACT_EMAIL_TO=
MAIL_TO=
# Optional SMTP configuration for real delivery
# Example for Gmail: use smtp.gmail.com, port 587, TLS, and your full Gmail address as username.
CONTACT_SMTP_HOST=
CONTACT_SMTP_PORT=
CONTACT_SMTP_USERNAME=
CONTACT_SMTP_PASSWORD=
CONTACT_SMTP_SECURE=

# Optional: change HOST/PORT if running PHP built-in server
APP_HOST=
APP_PORT=

# Notes:
# - The project reads these variables via getenv(); load them into environment
#   (export on Linux/macOS, setx or PowerShell on Windows) or use phpdotenv.
# - If SMTP is not configured, the app will try the local PHP mail() method and log the message if delivery fails.
